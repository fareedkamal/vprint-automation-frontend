# Copy to .env.local — never commit .env.local
#
# Public URL of the vprint-automation API (Express + /internal/dashboard/*).
# Local: run backend with WEBHOOK_PORT=3001 if this Next app uses port 3000, then:
NEXT_PUBLIC_APP_URL=http://localhost:3001
#
# Production: your deployed service URL, no trailing slash, e.g.:
# NEXT_PUBLIC_APP_URL=https://vprint-automation-service.onrender.com
